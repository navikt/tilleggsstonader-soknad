{
  "name": "tilleggsstonader-soknad",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ci": "yarn --prefer-offline --frozen-lockfile && yarn --cwd src/backend ci",
    "build": "yarn lint && PUBLIC_URL=/tilleggsstonader/soknad webpack --config ./webpack/webpack.production.js && yarn --cwd src/backend build",
    "build:dev": "PUBLIC_URL=/tilleggsstonader/soknad webpack --config ./webpack/webpack.development.js",
    "start:dev": "PUBLIC_URL=/tilleggsstonader/soknad webpack serve --config ./webpack/webpack.development.js",
    "postinstall": "husky",
    "prepare": "husky",
    "lint": "eslint 'src/**/*'",
    "lint:fix": "eslint 'src/**/*' --fix"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css}": [
      "prettier --write",
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "tests/**/*.{js,jsx,ts,tsx,json,css}": [
      "prettier --write",
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@eslint/compat": "^2.0.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@navikt/aksel": "^8.10.2",
    "@sentry/types": "^10.50.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@types/react-router-dom": "^5.3.3",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@typescript-eslint/typescript-estree": "^8.34.0",
    "babel-loader": "^10.1.0",
    "cookie-parser": "^1.4.7",
    "css-loader": "^7.1.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "html-webpack-plugin": "^5.6.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^6.0.2",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.0",
    "webpack-dev-middleware": "^8.0.3",
    "webpack-dev-server": "^5.2.2",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@navikt/aksel-icons": "^8.10.2",
    "@navikt/ds-css": "^8.8.0",
    "@navikt/ds-react": "^8.10.2",
    "@navikt/ds-tokens": "^8.2.0",
    "@navikt/nav-dekoratoren-moduler": "^3.7.1",
    "@sentry/react": "^10.50.0",
    "@sentry/tracing": "^7.114.0",
    "@tanstack/react-query": "^5.100.5",
    "axios": "^1.15.0",
    "constate": "^3.3.3",
    "date-fns": "^4.1.0",
    "i18n-iso-countries": "^7.14.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.14.0",
    "styled-components": "^6.4.0",
    "uuid": "^13.0.0"
  },
  "resolutions": {
    "styled-components": "^6",
    "qs": "^6.15.0"
  }
}
